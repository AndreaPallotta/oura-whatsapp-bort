# Oura Ring API Configurations
OURA_CLIENT_ID=your_oura_client_id_here
OURA_CLIENT_SECRET=your_oura_client_secret_here

# Recipient WhatsApp phone number (no '+' or spaces, e.g., 15551234567)
RECIPIENT_PHONE=recipient_phone_number_here

# Language selection for the message (Options: en, it, fr, es)
LANGUAGE=en
